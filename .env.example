# CANJIA Flask 애플리케이션 환경 변수
# 실제 사용시에는 .env 파일로 이름을 바꾸고 실제 값으로 채워주세요

# Flask 설정
FLASK_APP=app.py
FLASK_ENV=development
SECRET_KEY=canjia-secret-key-2026-change-in-production

# 데이터베이스
DATABASE_URL=sqlite:///canjia.db

# 세션 설정
SESSION_TYPE=filesystem
PERMANENT_SESSION_LIFETIME=604800  # 7 days in seconds

# 서버 설정
HOST=0.0.0.0
PORT=5000
DEBUG=True

# 이메일 설정 (선택사항 - 2FA 이메일 발송 시 필요)
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=True
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-email-password

# 로깅 설정 (선택사항)
LOG_LEVEL=INFO
